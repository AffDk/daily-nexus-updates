APP_NAME=Daily Nexus Update
APP_ENV=development
HOST=127.0.0.1
PORT=8000
DEBUG=false

GEMINI_API_KEY=replace_me
GEMINI_MODEL=gemini-3.1-flash-lite

ELEVENLABS_API_KEY=replace_me
ELEVENLABS_VOICE_ID=replace_me
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ENABLE_VOICEOVER=false

YOUTUBE_CLIENT_SECRETS_FILE=secrets/youtube_client_secret.json
YOUTUBE_TOKEN_FILE=secrets/youtube_token.json
YOUTUBE_UPLOAD_ENABLED=false
YOUTUBE_PRIVACY_STATUS=private
YOUTUBE_CHANNEL_NAME=dailynexusupdate

FAILURE_EMAIL_ENABLED=false
FAILURE_EMAIL_TO=
FAILURE_EMAIL_FROM=
FAILURE_EMAIL_SUBJECT_PREFIX=[Daily Nexus Update]
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

OUTPUT_DIR=output
NEWS_MEMORY_FILE=data/news_memory.json
NEWS_MEMORY_ARCHIVE_FILE=data/news_memory_archive.json
CUSTOM_CA_BUNDLE=
TLS_ENFORCE_SYSTEM_ROOTS=true
MAX_STORIES=5
INTRO_SECONDS=8
OUTRO_SECONDS=14
MIN_STORY_SECONDS=30
MAX_STORY_SECONDS=90
MAX_VIDEO_SECONDS=300
AUDIO_CROSSFADE_SECONDS=1.2
RETRY_MAX_ATTEMPTS=3
RETRY_DELAY_SECONDS=300
RETRY_BACKOFF_MULTIPLIER=1.0
VIDEO_WIDTH=1920
VIDEO_HEIGHT=1080
STORY_SECONDS=8
FONT_PATH=
BACKGROUND_MUSIC_FILE=

FAILURE_EMAIL_ENABLED=true
FAILURE_EMAIL_TO=
FAILURE_EMAIL_FROM=
FAILURE_EMAIL_SUBJECT_PREFIX=[Daily Nexus Update]
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=
SMTP_USE_SSL=false
